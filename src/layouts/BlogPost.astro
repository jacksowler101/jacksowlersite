---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { tagSlug } from '../utils/tags';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: MarkdownHeading[];
	readingTime?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	headings = [],
	readingTime,
} = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			.article__head {
				padding-top: 0.5em;
			}
			.article__meta {
				margin: 0 0 0.8em 0;
			}
			.article__head h1 {
				font-size: 2.7rem;
				margin: 0 0 0.3em 0;
			}
			.article__dek {
				font-size: 1.2rem;
				color: var(--ink-soft);
				font-style: italic;
				margin: 0 0 0.8em 0;
			}
			.article__tags {
				margin: 0.4em 0 0 0;
			}
			.article__updated {
				font-family: var(--font-sans);
				font-size: 0.8rem;
				color: var(--ink-faint);
				margin: 0.4em 0 0 0;
			}
			.article__hero {
				margin: 1.8em 0;
			}
			.article__hero img {
				width: 100%;
				border-radius: 6px;
				border: 1px solid var(--rule);
			}
			.divider {
				border: none;
				border-top: 1px solid var(--rule);
				margin: 1.6em 0 2em 0;
			}
			.toc {
				border: 1px solid var(--rule);
				border-radius: 6px;
				background: var(--paper-raised);
				padding: 1em 1.3em;
				margin: 0 0 2.2em 0;
			}
			.toc__title {
				margin: 0 0 0.4em 0;
			}
			.toc ol {
				margin: 0;
				padding-left: 1.2em;
				font-family: var(--font-sans);
				font-size: 0.95rem;
			}
			.toc li {
				margin: 0.3em 0;
			}
			.toc li.sub {
				margin-left: 1em;
				list-style: lower-roman;
			}
			.toc a {
				color: var(--ink-soft);
				text-decoration: none;
			}
			.toc a:hover {
				color: var(--accent);
			}
			.prose :global(h2),
			.prose :global(h3) {
				scroll-margin-top: 1em;
			}
			.prose > p:first-of-type::first-letter {
				font-family: var(--font-display);
				font-size: 3.4em;
				font-weight: 600;
				float: left;
				line-height: 0.78;
				padding: 0.04em 0.09em 0 0;
				color: var(--accent);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="article__head">
					<p class="article__meta eyebrow">
						<FormattedDate date={pubDate} />{readingTime ? ` · ${readingTime} min read` : ''}
					</p>
					<h1>{title}</h1>
					{description && <p class="article__dek">{description}</p>}
					{
						tags.length > 0 && (
							<p class="article__tags">
								{tags.map((t) => (
									<a class="tag" href={`/topics/${tagSlug(t)}/`}>
										{t}
									</a>
								))}
							</p>
						)
					}
					{
						updatedDate && (
							<p class="article__updated">
								Updated <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>

				{
					heroImage && (
						<figure class="article__hero">
							<Image width={1200} height={600} src={heroImage} alt="" />
						</figure>
					)
				}

				<hr class="divider" />

				{
					toc.length >= 3 && (
						<nav class="toc" aria-label="Table of contents">
							<p class="toc__title eyebrow">Contents</p>
							<ol>
								{toc.map((h) => (
									<li class={h.depth === 3 ? 'sub' : ''}>
										<a href={`#${h.slug}`}>{h.text}</a>
									</li>
								))}
							</ol>
						</nav>
					)
				}

				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

---
import Base from './Base.astro';

interface Props {
	title: string;
	description: string;
	status?: 'live' | 'in-progress' | 'planned';
	disciplines?: string[];
	date?: Date;
}

const { title, description, status, disciplines = [] } = Astro.props;
const statusLabel =
	status === 'in-progress' ? 'In progress' : status === 'planned' ? 'Planned' : 'Live';
---

<Base title={title} description={description} width="narrow">
	<article>
		<header class="project__head">
			<p class="eyebrow"><a href="/projects">← Projects</a></p>
			<h1>{title}</h1>
			<p class="project__dek">{description}</p>
			<p class="project__meta">
				{status && <span class={`badge badge--${status}`}>{statusLabel}</span>}
				{disciplines.map((d) => <span class="discipline">{d}</span>)}
			</p>
		</header>
		<hr class="divider" />
		<div class="prose">
			<slot />
		</div>
	</article>
	<style>
		.project__head {
			padding-top: 0.5em;
		}
		.project__head h1 {
			font-size: 2.4rem;
			margin: 0.2em 0 0.3em 0;
		}
		.project__dek {
			font-size: 1.15rem;
			color: var(--ink-soft);
			margin: 0 0 0.6em 0;
		}
		.project__meta {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.7em;
			margin: 0.4em 0 0 0;
		}
		.eyebrow a {
			color: var(--ink-faint);
			text-decoration: none;
		}
		.eyebrow a:hover {
			color: var(--accent);
		}
		.divider {
			border: none;
			border-top: 1px solid var(--rule);
			margin: 1.4em 0 2em 0;
		}
		.prose :global(img) {
			border-radius: 8px;
			border: 1px solid var(--rule);
		}
	</style>
</Base>

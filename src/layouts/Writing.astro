---
import type { MarkdownHeading } from 'astro';
import Base from './Base.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	disciplines?: string[];
	headings?: MarkdownHeading[];
	readingTime?: number;
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	disciplines = [],
	headings = [],
	readingTime,
} = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Base title={title} description={description} width="narrow">
	<article>
		<header class="article__head">
			<p class="article__meta eyebrow">
				<FormattedDate date={pubDate} />{readingTime ? ` · ${readingTime} min read` : ''}
			</p>
			<h1>{title}</h1>
			{description && <p class="article__dek">{description}</p>}
			{
				disciplines.length > 0 && (
					<p class="article__disc">
						{disciplines.map((d) => (
							<span class="discipline">{d}</span>
						))}
					</p>
				)
			}
			{
				updatedDate && (
					<p class="article__updated">
						Updated <FormattedDate date={updatedDate} />
					</p>
				)
			}
		</header>
		<hr class="divider" />
		{
			toc.length >= 3 && (
				<nav class="toc" aria-label="Table of contents">
					<p class="toc__title eyebrow">Contents</p>
					<ol>
						{toc.map((h) => (
							<li class={h.depth === 3 ? 'sub' : ''}>
								<a href={`#${h.slug}`}>{h.text}</a>
							</li>
						))}
					</ol>
				</nav>
			)
		}
		<div class="prose">
			<slot />
		</div>
	</article>
	<style>
		.article__head {
			padding-top: 0.5em;
		}
		.article__meta {
			margin: 0 0 0.7em 0;
		}
		.article__head h1 {
			font-size: 2.5rem;
			margin: 0 0 0.3em 0;
		}
		.article__dek {
			font-size: 1.15rem;
			color: var(--ink-soft);
			margin: 0 0 0.6em 0;
		}
		.article__disc {
			display: flex;
			flex-wrap: wrap;
			gap: 0.7em;
			margin: 0.3em 0 0 0;
		}
		.article__updated {
			font-family: var(--font-sans);
			font-size: 0.8rem;
			color: var(--ink-faint);
			margin: 0.4em 0 0 0;
		}
		.divider {
			border: none;
			border-top: 1px solid var(--rule);
			margin: 1.4em 0 2em 0;
		}
		.toc {
			border: 1px solid var(--rule);
			border-radius: 10px;
			background: var(--surface);
			padding: 1em 1.2em;
			margin: 0 0 2em 0;
		}
		.toc__title {
			margin: 0 0 0.4em 0;
		}
		.toc ol {
			margin: 0;
			padding-left: 1.2em;
			font-size: 0.95rem;
		}
		.toc li {
			margin: 0.3em 0;
		}
		.toc li.sub {
			margin-left: 1em;
			list-style: lower-roman;
		}
		.toc a {
			color: var(--ink-soft);
			text-decoration: none;
		}
		.toc a:hover {
			color: var(--accent);
		}
		.prose :global(h2),
		.prose :global(h3) {
			scroll-margin-top: 1em;
		}
		.prose :global(img) {
			border-radius: 8px;
			border: 1px solid var(--rule);
		}
	</style>
</Base>
